{
  "name": "giohomestudio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start -p 3200",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test": "playwright test",
    "test:ui": "playwright test --headed",
    "test:api": "playwright test --grep \"GET|POST|PATCH|DELETE|Commercial:|Mode 2:\"",
    "test:commercial": "playwright test --grep \"Commercial|Mode 2|Render\"",
    "test:pages": "playwright test --grep \"UI:\"",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.33.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
