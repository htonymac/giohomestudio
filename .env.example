# ============================================================
# GioHomeStudio — Environment Variable Template
# Copy this to .env and fill in your values.
# ============================================================

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/giohomestudio_db"

KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
KLING_API_BASE_URL=https://api.klingai.com

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io/v1

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Music Provider: kie_ai | stock_library | mubert | stable_audio | manual
MUSIC_PROVIDER=stock_library
KIE_AI_API_KEY=
KIE_AI_API_BASE_URL=https://api.kie.ai

# FAL.ai gateway — covers Stable Audio (instrumental ≤47s), image gen, video gen
FAL_KEY=your_fal_key_here

# Mubert B2B API — required for instrumental tracks >47s
# Without this, tracks >47s fall back to stock library automatically
# Get key from: https://mubert.com/render/pricing (B2B API plan)
MUBERT_PAT=your_mubert_pat_here

STORAGE_BASE_PATH=./storage

NEXT_PUBLIC_APP_URL=http://localhost:3200
NODE_ENV=development
