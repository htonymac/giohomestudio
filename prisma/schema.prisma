generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?   // null for OAuth-only users
  phone           String?
  role            String    @default("user") // user | admin
  termsAcceptedAt DateTime?
  termsVersion    String?   // e.g. "1.0"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
  sessions        Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Business Models ─────────────────────────────────────────────────────────

model DestinationPage {
  id           String        @id @default(cuid())
  name         String
  platform     PagePlatform
  handle       String?
  notes        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contentItems ContentItem[]

  @@map("destination_pages")
}

model ContentItem {
  id                String           @id @default(cuid())
  mode              ContentMode      @default(FREE)
  status            ContentStatus    @default(PENDING)
  originalInput     String
  enhancedPrompt    String?
  narrationScript   String?   // natural spoken text used for voice generation (not cinematic description)
  supervisorPlan    Json?     // stored OrchestrationPlan from local LLM supervisor
  voiceSource       String?   // "generated" | "uploaded" | "fallback" | "stock" | "manual"
  musicSource       String?   // "generated" | "uploaded" | "fallback" | "stock" | "pixabay" | "manual"
  requestedVideoProvider   String?
  videoProvider            String?
  voiceProvider            String?
  requestedVoiceProvider   String?   // user-selected voice provider: "elevenlabs" | "mock_voice"
  voiceId                  String?   // requested ElevenLabs voice ID
  voiceLanguage            String?   // language hint e.g. "en", "es", "fr"
  narrationSpeed           Float?    // speech rate 0.7-1.2, default 1.0
  narrationVolume          Float?    // voice level in FFmpeg mix 0.0-1.0, default 1.0
  outputMode               String?   // "text_to_video" | "text_to_audio" | "images_audio" | "hybrid" | "video_to_video"
  audioMode                String?   // "voice_music" | "voice_only" | "music_only" | "audio_only"
  castingCharacters        String[]  // character names selected for this generation
  musicProvider            String?
  requestedMusicProvider   String?   // user-selected music provider
  musicVolume              Float?    // music ducking level 0.0-1.0, default 0.85
  musicGenre               String?   // cinematic | electronic | acoustic | orchestral | ambient | hip_hop
  musicRegion              String?   // global | western | latin | asian | middle_eastern | african
  videoQuality             String?   // draft | standard | high
  videoType                String?   // cinematic | ad_promo | realistic | animation | storytelling | social_short
  visualStyle              String?   // photorealistic | stylized | anime | 3d | cinematic_dark | bright_commercial
  subjectType              String?   // human | animal | product | scene_only | custom_character
  customSubjectDescription String?
  aiAutoMode               Boolean   @default(true)
  aspectRatio              String?   // "9:16" | "16:9" | "1:1" — output format, drives preview framing
  castingEthnicity         String?   // african | black | white | asian | arab | mixed | auto
  castingGender            String?   // male | female | nonbinary | mixed_gender
  castingAge               String?   // child | teen | young_adult | adult | senior
  castingCount             String?   // solo | duo | group | crowd
  cultureContext           String?   // african | arab | asian | latin | western | global
  referenceImageUrl        String?   // URL of a visual reference image
  storyContext             String?   // story context/continuation brief passed to the prompt enhancer
  previousContentItemId    String?   // ID of the item this scene continues from
  storyThreadId            String?   // shared thread ID linking scenes in the same story
  voiceLocale              String?   // en-NG-polished, en-GH-standard, etc.
  voiceAccentSubtype       String?   // yoruba, igbo, hausa, standard, polished
  voiceDeliveryStyle       String?   // commercial, storytelling, news_anchor, etc.
  voiceMatchType           String?   // exact, close, library, generic
  voiceCustomInstruct      String?   // user's custom narration instruction
  overlayLayers            Json?     // array of OverlayLayer objects applied to the video
  videoPath         String?
  voicePath         String?
  musicPath         String?
  mergedOutputPath  String?
  durationSeconds   Int?
  notes             String?
  destinationPageId String?
  destinationPage   DestinationPage? @relation(fields: [destinationPageId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  approvedAt        DateTime?
  rejectedAt        DateTime?
  scheduledAt       DateTime?
  publishedAt       DateTime?
  lastPostedAt      DateTime?
  repostCount       Int              @default(0)
  repostCooldownDays Int?            // minimum days between reposts
  repostEligible    Boolean          @default(false)
  versions          ContentVersion[]
  jobs              Job[]
  reviewActions     ReviewAction[]

  @@map("content_items")
}

// Character voice registry — maps character names to specific ElevenLabs voices
// Used for multi-voice dialogue to ensure consistent casting across episodes.
// Extended in Pass D: full character profile with image, visual description, role, default speech style.
model CharacterVoice {
  id                 String   @id @default(cuid())
  name               String   @unique  // character name e.g. "JOHN", "NARRATOR", "MAMA"
  gender             String?  // "male" | "female" | "boy" | "girl"
  toneClass          String?  // "bass" | "tenor" | "soft" | "commanding" | "elder" | "youthful"
  accent             String?  // "american" | "british" | "african" | "nigerian" | "neutral"
  language           String?  // "en" | "pidgin" | "yo" | "ig" | "ha"
  voiceId            String?  // ElevenLabs voice ID
  voiceName          String?  // human-readable voice name for display
  isNarrator         Boolean  @default(false)
  notes              String?
  // Pass D — full character profile
  imageUrl           String?  // URL to character portrait image
  visualDescription  String?  // appearance/style for prompt injection e.g. "tall Nigerian man in agbada"
  role               String?  // protagonist | antagonist | narrator | supporting | comic_relief | elder | child
  defaultSpeechStyle String?  // normal | whisper | emotional | commanding | trembling
  // Multi-angle reference images for video generation consistency
  referenceImages    Json?    // [{url: string, angle: string, label: string}]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("character_voices")
}

model ContentVersion {
  id               String        @id @default(cuid())
  contentItemId    String
  versionNumber    Int
  enhancedPrompt   String?
  videoPath        String?
  voicePath        String?
  musicPath        String?
  mergedOutputPath String?
  status           ContentStatus
  reason           String?
  createdAt        DateTime      @default(now())
  contentItem      ContentItem   @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@map("content_versions")
}

model Job {
  id            String      @id @default(cuid())
  contentItemId String
  type          JobType
  status        JobStatus   @default(QUEUED)
  providerUsed  String?
  providerJobId String?
  outputPath    String?
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@map("jobs")
}

model ReviewAction {
  id            String           @id @default(cuid())
  contentItemId String
  action        ReviewActionType
  reviewerNote  String?
  createdAt     DateTime         @default(now())
  contentItem   ContentItem      @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@map("review_actions")
}

model AlertLog {
  id            String      @id @default(cuid())
  contentItemId String?
  channel       String
  message       String
  status        AlertStatus @default(PENDING)
  error         String?
  sentAt        DateTime?
  createdAt     DateTime    @default(now())

  @@map("alerts_log")
}

model ProviderConfig {
  id           String   @id @default(cuid())
  providerType String
  providerName String
  isActive     Boolean  @default(true)
  config       Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerType, providerName])
  @@map("provider_configs")
}

enum ContentStatus {
  PENDING
  ENHANCING
  GENERATING_VIDEO
  GENERATING_VOICE
  GENERATING_MUSIC
  MERGING
  IN_REVIEW
  APPROVED
  REJECTED
  FAILED
  PUBLISHED
  ARCHIVED
}

enum ContentMode {
  FREE
  COMMERCIAL
}

enum PagePlatform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  FACEBOOK
  OTHER
}

enum JobType {
  PROMPT_ENHANCE
  VIDEO_GENERATE
  VOICE_GENERATE
  MUSIC_GENERATE
  FFMPEG_MERGE
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ReviewActionType {
  APPROVED
  REJECTED
  SENT_BACK
  SAVED_DRAFT
  MARKED_FOR_LATER
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
}

// ── Commercial Maker ───────────────────────────────────────────────────────────

model CommercialProject {
  id                String            @id @default(cuid())
  projectName       String
  aspectRatio       String            @default("9:16")   // "9:16" | "16:9" | "1:1"
  brandName         String?
  brandLogoPath     String?
  colorAccent       String?
  tagline           String?
  ctaMethod            String?           // "whatsapp" | "call" | "telegram"
  ctaValue             String?           // primary phone or handle
  ctaValueSecondary    String?           // secondary phone number
  ctaLabel             String?
  voiceId              String?           // ElevenLabs voice ID for narration
  voiceLanguage        String?           // accent/language hint passed to TTS
  targetDurationSec    Int?              // desired total commercial length in seconds
  autoDistribute       Boolean           @default(false)  // divide targetDurationSec evenly across slides
  captionMaxWords      Int               @default(8)      // AI caption generation limit (words)
  captionMaxChars      Int?              // optional character limit for AI caption generation
  transitionType        String?           // "fade" | "slide-left" | "slide-right" | "zoom-in" | null = none
  transitionDurationSec Float?            // transition duration in seconds (default 0.5)
  globalCaptionPosition String?           // "top" | "center" | "bottom" — overrides all per-slide positions when set
  renderQuality         String?           // "draft" | "standard" | "high" | "cinema" — controls CRF + preset
  musicPath            String?           // path to music file (uploaded or stock)
  musicSource          String?           // "uploaded" | "stock" | "pixabay"
  musicVolume          Float             @default(0.85)
  narrationVolume      Float             @default(1.0)   // voice level in final FFmpeg mix 0.0-2.0
  narrationScript      String?           // full narration text (assembled from slide narrationLines)
  enhancementPreset    String?           // "cinematic" | "hdr" | "natural" | "clean_social" | "warm_promo"
  enhancementLevel     Int?              // global enhancement level 1-100 (applied to all slides)
  renderStatus      String            @default("draft")  // "draft" | "rendering" | "ready" | "failed"
  contentItemId     String?           // linked ContentItem when rendered
  destinationPageId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  slides            CommercialSlide[]

  @@map("commercial_projects")
}

model CommercialSlide {
  id                  String             @id @default(cuid())
  projectId           String
  slideOrder          Int
  imagePath           String?            // absolute path to uploaded image
  imageFileName       String?            // original filename for display
  captionOriginal     String?
  captionPolished     String?
  captionApproved     Boolean            @default(false)
  narrationLine       String?            // spoken text for this slide
  durationMs          Int                @default(3000)   // how long to show this slide
  brandingEnabled     Boolean            @default(false)
  enhancementSettings Json?              // per-slide overrides: {brightness, contrast, saturation}
  status              String             @default("draft") // "draft" | "ready" | "missing_media"
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  project             CommercialProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("commercial_slides")
}

// ── Story Bank ────────────────────────────────────────────────────────────────

model StoryIdea {
  id              String   @id @default(cuid())
  title           String
  body            String?
  tags            String   @default("") // comma-separated
  rating          Int      @default(0)  // 0-5 stars
  mode            String?  // FREE, COMMERCIAL, SERIES
  platform        String?  // youtube, instagram, tiktok
  status          String   @default("idea") // idea, scripted, in_production, used
  usedInContentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("story_ideas")
}

// ── A/B Testing ───────────────────────────────────────────────────────────────

model ABTest {
  id              String       @id @default(cuid())
  name            String       // "Homepage reel — title test"
  contentItemId   String       // source content item
  status          String       @default("active") // active, paused, completed
  winnerVariantId String?      // which variant won
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  variants        ABVariant[]

  @@map("ab_tests")
}

model ABVariant {
  id           String   @id @default(cuid())
  testId       String
  label        String   // "A", "B", "C"
  title        String?  // different title
  caption      String?  // different caption
  thumbnailUrl String?  // different thumbnail
  hashtags     String?  // different tags
  views        Int      @default(0)
  clicks       Int      @default(0)
  engagement   Float    @default(0) // engagement rate %
  isWinner     Boolean  @default(false)
  publishedAt  DateTime?
  platform     String?  // where this variant was published
  postUrl      String?
  createdAt    DateTime @default(now())
  test         ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("ab_variants")
}

// ── Ad Image Editor ──────────────────────────────────────────────────────────

model AdProject {
  id              String          @id @default(cuid())
  name            String          @default("Untitled Ad")
  type            AdProjectType   @default(AD)
  canvasWidth     Int             @default(1080)
  canvasHeight    Int             @default(1080)
  background      String          @default("#FFFFFF")
  backgroundFinish String         @default("none")  // "none" | "matte" | "gloss"
  gradient        String?         // CSS gradient string if used
  templateId      String?         // which ad template was used to start
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  layers          AdLayer[]
  assets          AdAsset[]
  aiJobs          AIEditJob[]

  @@map("ad_projects")
}

model AdLayer {
  id          String     @id @default(cuid())
  projectId   String
  type        String     // "image" | "text" | "whatsapp" | "cta" | "price" | "shape"
  positionX   Float      @default(0)
  positionY   Float      @default(0)
  width       Float      @default(200)
  height      Float      @default(60)
  rotation    Float      @default(0)
  zIndex      Int        @default(0)
  locked      Boolean    @default(false)
  visible     Boolean    @default(true)
  content     String     @default("")   // text content or image URL
  style       Json       @default("{}")  // LayerStyle as JSON
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  project     AdProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ad_layers")
}

model AdAsset {
  id          String     @id @default(cuid())
  projectId   String
  sourceType  String     // "upload" | "ai_edit" | "ai_generate" | "library" | "bg_remove"
  originalUrl String?    // original image before edits
  currentUrl  String     // current version URL
  fileName    String?
  mimeType    String?
  sizeBytes   Int?
  metadata    Json       @default("{}")
  createdAt   DateTime   @default(now())
  project     AdProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ad_assets")
}

model AIEditJob {
  id             String     @id @default(cuid())
  projectId      String
  mode           String     // "ad" | "movie" | "banner" | "text_to_image"
  editType       String     // "bg_remove" | "bg_replace" | "style_transfer" | "generate" | "upscale" | "inpaint" | "outpaint"
  originalPrompt String
  enhancedPrompt String?
  provider       String?    // "fal_ai" | "segmind" | "remove_bg"
  inputAssetId   String?    // source AdAsset ID
  outputAssetId  String?    // result AdAsset ID
  outputUrl      String?
  status         AIEditStatus @default(QUEUED)
  error          String?
  createdAt      DateTime   @default(now())
  completedAt    DateTime?
  project        AdProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ai_edit_jobs")
}

enum AdProjectType {
  AD
  BANNER
  FLYER
  MOVIE_POSTER
  EVENT
}

enum AIEditStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ── Movie & Series Planner Models ───────────────────────────────────────────

model MovieProject {
  id              String        @id @default(cuid())
  title           String        @default("Untitled Movie")
  idea            String        // short user input
  expandedStory   String?       // optional longer description
  genre           String?
  style           String?       // storytelling style
  format          String?       // output format (audio_only, audio_image, etc.)
  productionMode  String?
  planningDepth   String?       @default("smart")
  tone            String?
  setting         String?
  duration        String?       @default("10 min")
  language        String?       @default("English")
  summary         String?       // AI-generated movie summary
  storyArc        Json?         // { setup, tension, climax, resolution }
  soundPlan       String?
  musicDirection  String?
  visualDirection String?
  continuityNotes Json?         // string[]
  missingAssets   Json?         // string[]
  reviewerNotes   Json?         // string[]
  estimatedCredits Int?         @default(0)
  status          MovieStatus   @default(DRAFT)
  cast            Json?         // [{ characterId, role }]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  scenes          MovieScene[]

  @@map("movie_projects")
}

model MovieScene {
  id                String    @id @default(cuid())
  projectId         String
  scene             Int       // scene number / order
  title             String
  goal              String?
  duration          String?
  characters        Json?     // string[] of character names
  visualDescription String?
  cameraDirection   String?
  dialogue          String?
  soundEffects      String?
  ambience          String?
  musicCue          String?
  generationMethod  String?   // image, video, image-to-video, audio-only, hybrid
  costLabel         String?   // cheap, balanced, premium
  status            String    @default("planned") // planned, approved, generating, generated, needs_edit, blocked
  generatedAssetUrl String?   // URL to generated video/image
  generatedAudioUrl String?   // URL to generated audio for this scene
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  project           MovieProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("movie_scenes")
}

enum MovieStatus {
  DRAFT
  PLANNING
  SCENES_READY
  RENDERING
  RENDERED
  ASSEMBLED
  EXPORTED
}

// ── Music Video Projects ────────────────────────────────────────────────────

model MusicVideoProject {
  id              String    @id @default(cuid())
  title           String    @default("Untitled Music Video")
  songTitle       String?
  songUrl         String?
  lyrics          String?
  videoMode       String?   // official, lyric, visualizer, commercial, performance, dance, children, image-mv
  visualStyle     String?
  artistName      String?
  status          String    @default("draft") // draft, planned, rendering, rendered, assembled
  musicProfile    Json?     // from intelligence analysis
  storyboard      Json?     // scene array
  motionboard     Json?     // energy curve
  recommendations Json?
  renderedVideoUrl String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("music_video_projects")
}
